{
  "description": "ACM hooks for experience retrieval/injection, signal collection, and experience generation",
  "hooks": {
    "SessionStart": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/session-start.js",
        "timeout": 15000
      }]
    }],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/stop.js",
          "timeout": 5000
        }]
      },
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/session-end.js",
          "timeout": 10000
        }]
      }
    ],
    "PostToolUse": [{
      "matcher": "Bash|Edit|Write|Read|Grep|Glob|NotebookEdit|WebFetch|WebSearch",
      "hooks": [{
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/post-tool-use.js",
        "timeout": 5000
      }]
    }],
    "PostToolUseFailure": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/post-tool-use-failure.js",
        "timeout": 5000
      }]
    }],
    "UserPromptSubmit": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/user-prompt-submit.js",
        "timeout": 5000
      }]
    }]
  }
}
