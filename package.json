{
  "name": "okitegami-acm",
  "version": "0.1.0",
  "description": "Associative Context Memory (ACM) MCP Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "start": "node dist/index.js",
    "experiment": "tsx experiments/runner/cli.ts",
    "experiment:dry": "tsx experiments/runner/cli.ts --dry-run",
    "prepare": "husky"
  },
  "author": "Hiroshi Yamato <yamato@signalcompose.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "tsx": "^4.19.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "{src,tests,experiments/harness,experiments/runner}/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "experiments/tasks/**/*.ts": [
      "prettier --write"
    ]
  }
}
